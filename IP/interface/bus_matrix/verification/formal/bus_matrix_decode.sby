# bus_matrix_decode.sby — SymbiYosys configuration for address decoder properties.
#
# Verifies P5, P6 (decode one-hot, decode error mutex) with bounded model checking.
# Run: sby -f bus_matrix_decode.sby

[options]
mode bmc
depth 20
multiclock off

[engines]
smtbmc boolector

[script]
read -sv bus_matrix_arb.sv
read -sv bus_matrix_decoder.sv
read -sv bus_matrix_core.sv
read -sv bus_matrix_props.sv
prep -top bus_matrix_props

[files]
../../design/rtl/verilog/bus_matrix_arb.sv
../../design/rtl/verilog/bus_matrix_decoder.sv
../../design/rtl/verilog/bus_matrix_core.sv
bus_matrix_props.sv
