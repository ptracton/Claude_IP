# synth_bus_matrix_axi_vhdl.ys — Yosys VHDL synthesis for bus_matrix_axi
# Requires ghdl plugin (OSS CAD Suite).
# Run from IP/interface/bus_matrix/:
#   yosys synthesis/yosys/synth_bus_matrix_axi_vhdl.ys

plugin -i ghdl
ghdl --std=08 \
    design/rtl/vhdl/bus_matrix_decoder.vhd \
    design/rtl/vhdl/bus_matrix_arb.vhd \
    design/rtl/vhdl/bus_matrix_core.vhd \
    design/rtl/vhdl/bus_matrix_axi.vhd \
    -e bus_matrix_axi

synth -top bus_matrix_axi -flatten
stat
write_verilog -noattr synthesis/yosys/work/bus_matrix_axi_vhdl_synth.v
