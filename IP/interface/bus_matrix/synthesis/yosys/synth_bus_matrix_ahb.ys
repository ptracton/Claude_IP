# synth_bus_matrix_ahb.ys — Yosys SV synthesis for bus_matrix_ahb
# Run from IP/interface/bus_matrix/:
#   yosys synthesis/yosys/synth_bus_matrix_ahb.ys

read_verilog -sv design/rtl/verilog/bus_matrix_decoder.sv
read_verilog -sv design/rtl/verilog/bus_matrix_arb.sv
read_verilog -sv design/rtl/verilog/bus_matrix_core.sv
read_verilog -sv design/rtl/verilog/bus_matrix_ahb.sv

synth -top bus_matrix_ahb -flatten
stat
write_verilog -noattr synthesis/yosys/work/bus_matrix_ahb_synth.v
