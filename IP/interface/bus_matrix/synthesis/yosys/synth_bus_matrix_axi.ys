# synth_bus_matrix_axi.ys — Yosys SV synthesis for bus_matrix_axi
# Run from IP/interface/bus_matrix/:
#   yosys synthesis/yosys/synth_bus_matrix_axi.ys

read_verilog -sv design/rtl/verilog/bus_matrix_decoder.sv
read_verilog -sv design/rtl/verilog/bus_matrix_arb.sv
read_verilog -sv design/rtl/verilog/bus_matrix_core.sv
read_verilog -sv design/rtl/verilog/bus_matrix_axi.sv

synth -top bus_matrix_axi -flatten
stat
write_verilog -noattr synthesis/yosys/work/bus_matrix_axi_synth.v
