# Build artifacts
*.o
*.a
*.so
work-obj*.cf

# Firmware build outputs
firmware/build/
firmware/obj/
firmware/lib/

# Simulation work directories
verification/work/icarus/*/
verification/work/ghdl/*/
verification/work/ghdl_lint/*.o
verification/work/ghdl_lint/*.cf
verification/work/verilator/*/

# Formal verification run directories (sby creates these)
verification/formal/timer_apb/
verification/formal/timer_ahb/
verification/formal/timer_axi4l/
verification/formal/timer_wb/
verification/formal/work/

# Synthesis intermediates
synthesis/yosys/work/*.ys
synthesis/vivado/*.jou
synthesis/vivado/.Xil/
synthesis/vivado/db/
synthesis/vivado/incremental_db/
synthesis/quartus/db/
synthesis/quartus/incremental_db/

# Lint logs (regenerated by lint tool)
verification/lint/lint_results.log

# Waveform dumps
*.vcd
*.fst
*.ghw

# Python cache
__pycache__/
*.pyc
