# synth_timer_axi4l.ys — Yosys synthesis script for Timer IP (AXI4-Lite variant).
#
# Usage (from synthesis/yosys/):
#   yosys synth_timer_axi4l.ys
#
# Reads RTL from ../../design/rtl/verilog/
# Writes synthesised netlist to ./work/timer_axi4l_synth.v
# Prints resource summary (cell counts).

read_verilog -sv \
    ../../design/rtl/verilog/timer_core.sv \
    timer_regfile_synth.sv \
    ../../design/rtl/verilog/timer_axi4l_if.sv \
    ../../design/rtl/verilog/timer_axi4l.sv
synth -top timer_axi4l -flatten
stat
write_verilog -noattr work/timer_axi4l_synth.v
