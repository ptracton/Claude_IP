# synth_timer_wb_vhdl.ys — Yosys synthesis for Timer IP (Wishbone, VHDL-2008).
#
# Requires the ghdl plugin: yosys -m ghdl synth_timer_wb_vhdl.ys

plugin -i ghdl
ghdl --std=08 \
    ../../../../common/design/rtl/vhdl/claude_wb_if.vhd \
    ../../design/rtl/vhdl/timer_reg_pkg.vhd \
    ../../design/rtl/vhdl/timer_regfile.vhd \
    ../../design/rtl/vhdl/timer_core.vhd \
    ../../design/rtl/vhdl/timer_wb.vhd \
    -e timer_wb
synth -top timer_wb -flatten
stat
write_verilog -noattr work/timer_wb_vhdl_synth.v
