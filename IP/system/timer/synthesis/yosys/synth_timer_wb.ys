# synth_timer_wb.ys — Yosys synthesis script for Timer IP (Wishbone variant).
#
# Usage (from synthesis/yosys/):
#   yosys synth_timer_wb.ys
#
# Reads RTL from ../../design/rtl/verilog/
# Writes synthesised netlist to ./work/timer_wb_synth.v
# Prints resource summary (cell counts).

read_verilog -sv \
    ../../design/rtl/verilog/timer_core.sv \
    timer_regfile_synth.sv \
    ../../../../common/design/rtl/verilog/claude_wb_if.sv \
    ../../design/rtl/verilog/timer_wb.sv
synth -top timer_wb -flatten
stat
write_verilog -noattr work/timer_wb_synth.v
