# synth_timer_apb_vhdl.ys — Yosys synthesis for Timer IP (APB, VHDL-2008).
#
# Requires the ghdl plugin: yosys -m ghdl synth_timer_apb_vhdl.ys

plugin -i ghdl
ghdl --std=08 \
    ../../../../common/design/rtl/vhdl/claude_apb_if.vhd \
    ../../design/rtl/vhdl/timer_reg_pkg.vhd \
    ../../design/rtl/vhdl/timer_regfile.vhd \
    ../../design/rtl/vhdl/timer_core.vhd \
    ../../design/rtl/vhdl/timer_apb.vhd \
    -e timer_apb
synth -top timer_apb -flatten
stat
write_verilog -noattr work/timer_apb_vhdl_synth.v
