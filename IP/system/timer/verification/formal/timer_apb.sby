# timer_apb.sby — SymbiYosys formal verification for timer_apb (APB4).
#
# Usage (from the verification/formal directory):
#   sby -f timer_apb.sby
#
# Modes: bmc (bounded model check, depth 20)
# All assertions are in timer_apb_formal.sv (flat wrapper — no bind required).

[options]
mode bmc
depth 20

[engines]
smtbmc boolector

[script]
read -formal timer_regfile_synth.sv
read -formal timer_core.sv
read -formal claude_apb_if.sv
read -formal timer_apb_formal.sv
prep -top timer_apb_formal

[files]
../../synthesis/yosys/timer_regfile_synth.sv
../../design/rtl/verilog/timer_core.sv
../../../../common/design/rtl/verilog/claude_apb_if.sv
timer_apb_formal.sv
