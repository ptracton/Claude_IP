# timer_axi4l.sby — SymbiYosys formal verification for timer_axi4l (AXI4-Lite).
#
# Usage (from the verification/formal directory):
#   sby -f timer_axi4l.sby
#
# Modes: bmc (bounded model check, depth 20)
# All assertions are in timer_axi4l_formal.sv (flat wrapper — no bind required).

[options]
mode bmc
depth 20

[engines]
smtbmc boolector

[script]
read -formal timer_regfile_synth.sv
read -formal timer_core.sv
read -formal timer_axi4l_if.sv
read -formal timer_axi4l_formal.sv
prep -top timer_axi4l_formal

[files]
../../synthesis/yosys/timer_regfile_synth.sv
../../design/rtl/verilog/timer_core.sv
../../design/rtl/verilog/timer_axi4l_if.sv
timer_axi4l_formal.sv
